<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme -->
    <style name="Theme.BBreApp" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/bbre_primary</item>
        <item name="colorPrimaryDark">@color/bbre_primary_dark</item>
        <item name="colorAccent">@color/bbre_accent</item>
        <item name="android:statusBarColor">@color/bbre_primary_dark</item>
        <item name="android:navigationBarColor">@color/bbre_primary_dark</item>
        <item name="android:windowBackground">@color/background_primary</item>
    </style>

    <!-- Splash Screen Theme -->
    <style name="Theme.BBreApp.Splash" parent="Theme.Material3.Light.NoActionBar">
        <item name="android:windowBackground">@drawable/splash_background</item>
        <item name="android:statusBarColor">@color/bbre_primary_dark</item>
        <item name="android:navigationBarColor">@color/bbre_primary_dark</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowFullscreen">false</item>
    </style>

    <!-- Button Styles -->
    <style name="Widget.BBreApp.Button.Primary" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/bbre_primary</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:padding">16dp</item>
    </style>

    <style name="Widget.BBreApp.Button.Secondary" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/bbre_primary</item>
        <item name="android:textColor">@color/bbre_primary</item>
        <item name="cornerRadius">12dp</item>
    </style>

    <!-- Input Field Style -->
    <style name="Widget.BBreApp.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/bbre_primary</item>
        <item name="hintTextColor">@color/bbre_primary</item>
        <item name="boxCornerRadiusTopStart">8dp</item>
        <item name="boxCornerRadiusTopEnd">8dp</item>
        <item name="boxCornerRadiusBottomStart">8dp</item>
        <item name="boxCornerRadiusBottomEnd">8dp</item>
    </style>

    <!-- Card Style -->
    <style name="Widget.BBreApp.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/surface</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">4dp</item>
    </style>
</resources>
