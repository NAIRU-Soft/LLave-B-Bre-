<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:drawable="@color/bbre_primary_dark" />
    
    <!-- Gradient overlay -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="135"
                android:startColor="@color/bbre_primary"
                android:endColor="@color/bbre_primary_dark"
                android:type="linear" />
        </shape>
    </item>
</layer-list>
