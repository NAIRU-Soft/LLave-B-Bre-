<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Title -->
        <TextView
            android:id="@+id/tvDialogTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Agregar Nueva Llave"
            android:textColor="@color/bbre_primary"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <!-- Key Type Label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tipo de Llave (Banco)"
            android:textColor="@color/gray_dark"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <!-- Key Type Spinner/Selector -->
        <Spinner
            android:id="@+id/spinnerKeyType"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/security_badge_background"
            android:layout_marginBottom="16dp"
            android:padding="8dp" />

        <!-- Key Category (DataType) Label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Categoría de Llave"
            android:textColor="@color/gray_dark"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <!-- Key Category RadioGroup -->
        <RadioGroup
            android:id="@+id/rgCategory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="16dp">

            <RadioButton
                android:id="@+id/rbPhone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Celular"
                android:checked="true" />

            <RadioButton
                android:id="@+id/rbId"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cédula" />

            <RadioButton
                android:id="@+id/rbEmail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Correo Electrónico" />

            <RadioButton
                android:id="@+id/rbRandom"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Código Alfanumérico Aleatorio (Único)" />

        </RadioGroup>

        <!-- Key Value Input -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilKeyValue"
            style="@style/Widget.BBreApp.TextInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Valor de la llave"
            android:layout_marginBottom="24dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etKeyValue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCancel"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cancelar"
                android:textColor="@color/gray_dark"
                android:layout_marginEnd="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSave"
                style="@style/Widget.BBreApp.Button.Primary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Guardar" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>
