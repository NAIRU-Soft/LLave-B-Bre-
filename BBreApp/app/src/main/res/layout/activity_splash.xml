<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/splash_background"
    android:padding="32dp">

    <!-- BBre Logo -->
    <ImageView
        android:id="@+id/ivBBreLogo"
        android:layout_width="200dp"
        android:layout_height="80dp"
        android:src="@drawable/logo_bbre"
        android:contentDescription="@string/splash_bbre"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_chainStyle="packed"
        android:layout_marginTop="100dp" />

    <!-- BBre Text -->
    <TextView
        android:id="@+id/tvBBre"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/splash_bbre"
        android:textColor="@color/white"
        android:textSize="48sp"
        android:textStyle="bold"
        android:letterSpacing="0.2"
        app:layout_constraintTop_toBottomOf="@id/ivBBreLogo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="24dp" />

    <!-- Divider -->
    <View
        android:id="@+id/divider"
        android:layout_width="100dp"
        android:layout_height="2dp"
        android:background="@color/bbre_accent"
        app:layout_constraintTop_toBottomOf="@id/tvBBre"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp" />

    <!-- NairuSoft Logo -->
    <ImageView
        android:id="@+id/ivNairuSoftLogo"
        android:layout_width="150dp"
        android:layout_height="50dp"
        android:src="@drawable/logo_nairusoft"
        android:contentDescription="@string/splash_nairusoft"
        app:layout_constraintTop_toBottomOf="@id/divider"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="24dp" />

    <!-- NairuSoft Text -->
    <TextView
        android:id="@+id/tvNairuSoft"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/splash_nairusoft"
        android:textColor="@color/nairusoft_secondary"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/ivNairuSoftLogo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp" />

    <!-- Description -->
    <TextView
        android:id="@+id/tvDescription"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/splash_description"
        android:textColor="@color/white"
        android:textSize="14sp"
        android:textAlignment="center"
        android:alpha="0.9"
        app:layout_constraintTop_toBottomOf="@id/tvNairuSoft"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="32dp"
        android:layout_marginHorizontal="16dp" />

    <!-- Security Badge -->
    <LinearLayout
        android:id="@+id/securityBadge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:padding="12dp"
        android:background="@drawable/security_badge_background"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="48dp">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@android:drawable/ic_lock_lock"
            android:contentDescription="Security"
            app:tint="@color/bbre_accent" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Seguridad Bancaria"
            android:textColor="@color/white"
            android:textSize="12sp"
            android:layout_marginStart="8dp" />

    </LinearLayout>

    <!-- Loading Indicator -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:indeterminateTint="@color/bbre_accent"
        app:layout_constraintBottom_toTopOf="@id/securityBadge"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="24dp" />

</androidx.constraintlayout.widget.ConstraintLayout>
