<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_primary">
    
    <!-- Toolbar -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/bbre_primary"
        app:title="@string/settings_title"
        app:titleTextColor="@color/white"
        app:navigationIcon="@drawable/ic_back"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />
    
    <!-- Current Username -->
    <TextView
        android:id="@+id/tvCurrentUsername"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Usuario actual:"
        android:textSize="16sp"
        android:textColor="@color/text_primary"
        android:padding="16dp"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />
    
    <!-- Change Profile Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnChangeProfile"
        style="@style/Widget.BBreApp.Button.Primary"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:text="@string/settings_profile"
        android:textSize="16sp"
        app:cornerRadius="12dp"
        app:layout_constraintTop_toBottomOf="@id/tvCurrentUsername"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_margin="16dp" />
    
    <!-- Manage Keys Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnManageKeys"
        style="@style/Widget.BBreApp.Button.Secondary"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:text="@string/dashboard_my_keys"
        android:textSize="16sp"
        app:cornerRadius="12dp"
        app:layout_constraintTop_toBottomOf="@id/btnChangeProfile"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginHorizontal="16dp" />
    
    <!-- Logout Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnLogout"
        style="@style/Widget.BBreApp.Button.Secondary"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:text="@string/settings_logout"
        android:textSize="16sp"
        app:cornerRadius="12dp"
        app:layout_constraintTop_toBottomOf="@id/btnManageKeys"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="32dp" />
    
    <!-- Delete User Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnDeleteUser"
        style="@style/Widget.BBreApp.Button.Secondary"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:text="@string/settings_delete_user"
        android:textSize="16sp"
        android:textColor="@color/red_error"
        app:cornerRadius="12dp"
        app:layout_constraintTop_toBottomOf="@id/btnLogout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="16dp" />
    
</androidx.constraintlayout.widget.ConstraintLayout>
